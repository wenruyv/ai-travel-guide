.chat-list-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.cl-header {
  padding: 32rpx 32rpx 20rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #222;
}

.bill-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 16rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #ff8e53 0%, #ff6b3d 100%);
  border-radius: 20rpx;
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(255, 110, 60, 0.25);
}
.bh-left {
  display: flex;
  align-items: center;
}
.bh-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}
.bh-info {
  margin-left: 18rpx;
}
.bh-title {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}
.bh-sub {
  font-size: 22rpx;
  opacity: 0.86;
  margin-top: 4rpx;
}
.bh-right {
  text-align: right;
}
.bh-amount {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}
.bh-amount.bh-pos {
  color: #fff;
}
.bh-amount.bh-neg {
  color: #fff5b1;
}
.bh-amount.bh-neutral {
  color: #fff;
  opacity: 0.9;
}
.bh-tip {
  font-size: 22rpx;
  opacity: 0.88;
  margin-top: 4rpx;
}

.cl-empty {
  margin: 120rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.cl-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}

.cl-avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 16rpx;
  background: #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.cl-body {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.cl-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cl-name {
  font-size: 32rpx;
  color: #222;
  font-weight: 500;
}

.cl-time {
  font-size: 22rpx;
  color: #bbb;
}

.cl-msg {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cl-badge {
  position: absolute;
  top: 24rpx;
  right: 32rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 34rpx;
  background: #fa5151;
  color: #fff;
  font-size: 22rpx;
  line-height: 34rpx;
  text-align: center;
}