.filter-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f6fa;
}
.filter-label {
  width: 140rpx;
  font-size: 28rpx;
  color: #555;
}
.filter-input {
  flex: 1;
  font-size: 28rpx;
}
.picker {
  flex: 1;
  font-size: 28rpx;
  color: #2f80ed;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #eef3fd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
.ml16 {
  margin-left: 16rpx;
}
.match {
  text-align: center;
}
.match-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #27ae60;
}
.match-label {
  font-size: 20rpx;
  color: #8a8a8a;
}
.intro {
  background: #fafbfc;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
}
.guide-hint {
  font-size: 22rpx;
  color: #ff8e53;
  margin-top: 12rpx;
  padding: 6rpx 12rpx;
  background: #fff7f0;
  border-radius: 8rpx;
  display: inline-block;
}

.empty {
  text-align: center;
  color: #aaa;
  padding: 80rpx 0;
  font-size: 26rpx;
}
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2f80ed, #56ccf2);
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(47, 128, 237, 0.4);
}