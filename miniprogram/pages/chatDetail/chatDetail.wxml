<view class="chat-page">
  <scroll-view class="msg-list" scroll-y scroll-top="{{scrollTop}}" scroll-with-animation>
    <view class="msg-day">与 {{name}} 的对话</view>
    <view
      wx:for="{{messages}}"
      wx:key="index"
      class="msg-row {{item.from === 'me' ? 'mine' : 'other'}}"
    >
      <view wx:if="{{item.from !== 'me'}}" class="msg-avatar">{{avatar}}</view>
      <view class="msg-bubble">
        <text>{{item.text}}</text>
        <view class="msg-time">{{item.time}}</view>
      </view>
      <view wx:if="{{item.from === 'me'}}" class="msg-avatar mine-avatar">🙂</view>
    </view>
  </scroll-view>

  <view class="chat-input-bar">
    <input
      class="chat-input"
      value="{{input}}"
      placeholder="发条消息…"
      confirm-type="send"
      bindinput="onInput"
      bindconfirm="send"
    />
    <view class="chat-send {{input ? 'active' : ''}}" bindtap="send">发送</view>
  </view>
</view>