<view class="container">
  <!-- 头部空间信息 -->
  <view wx:if="{{space}}" class="space-hero">
    <view class="sh-cover">{{space.cover}}</view>
    <view class="sh-info">
      <view class="sh-title">{{space.title}}</view>
      <view class="sh-meta">📍 {{space.destination}} · {{space.days}}天 · ¥{{space.budget}}</view>
      <view class="sh-meta">🗓 {{space.travelDate}}</view>
    </view>
  </view>

  <!-- tab 切换 -->
  <view class="tabs">
    <view class="tab {{tab === item.key ? 'on' : ''}}"
          wx:for="{{tabs}}" wx:key="key"
          data-tab="{{item.key}}" bindtap="onTab">{{item.label}}</view>
  </view>

  <!-- 行程共编 -->
  <view wx:if="{{tab === 'plan'}}" class="tab-pane">
    <view wx:if="{{!guide}}" class="empty">该空间还未绑定攻略</view>
    <view wx:else>
      <!-- 攻略 hero 元数据 -->
      <view class="card guide-hero">
        <view class="row between">
          <view class="gh-title">{{guide.title}}</view>
          <view class="gh-go" bindtap="onOpenGuide">查看原攻略 ›</view>
        </view>
        <view class="gh-summary mt8">{{guide.summary}}</view>
        <view class="row wrap mt8">
          <text class="gh-tag" wx:for="{{guide.tags}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="row mt8 gh-author">
          <text wx:if="{{guide.source === 'ai'}}">🤖 {{guide.author}}</text>
          <text wx:else>✍️ {{guide.author}}</text>
          <text class="gh-meta">📍{{guide.destination}} · {{guide.days}}天 · 预算¥{{guide.budget}}</text>
        </view>
      </view>

      <!-- 行程节点 -->
      <view class="card">
        <view class="sec-title">📅 行程安排</view>
        <view wx:for="{{planNodes}}" wx:key="_idx" wx:for-item="n" class="plan-node-inner">
          <view class="pn-day">Day {{n.day}}</view>
          <view class="pn-body">
            <view class="row between">
              <text class="pn-title">{{n.title}}</text>
              <text class="pn-cost" wx:if="{{n.cost}}">¥{{n.cost}}</text>
            </view>
            <view class="pn-loc mt8">📍 {{n.location}}</view>

            <!-- 备注：共编留痕 -->
            <view wx:if="{{editNodeIdx !== n._idx}}" class="pn-note mt8" data-idx="{{n._idx}}" bindtap="onTapNode">
              💡 {{n.note || '点我编辑备注'}}
            </view>
            <view wx:else class="pn-edit mt8">
              <textarea class="pn-input" value="{{editNoteDraft}}" bindinput="onEditNoteInput" auto-height />
              <view class="row mt8">
                <view class="btn btn-ghost" bindtap="onCancelEdit">取消</view>
                <view class="btn btn-primary ml8" bindtap="onSaveEdit">留痕保存</view>
              </view>
            </view>

            <!-- 时间 -->
            <view class="detail-row mt8" wx:if="{{n.timeSlot}}">
              <text class="detail-label">🕐 时间</text><text class="detail-val">{{n.timeSlot}}</text>
            </view>
            <!-- 交通 -->
            <view class="detail-row mt8" wx:if="{{n.transport}}">
              <text class="detail-label">🚗 交通</text><text class="detail-val">{{n.transport}}</text>
            </view>
            <!-- 住宿 -->
            <view class="detail-row mt8" wx:if="{{n.accommodation && n.accommodation !== '-'}}">
              <text class="detail-label">🏨 住宿</text><text class="detail-val">{{n.accommodation}}</text>
            </view>
            <!-- 餐饮 -->
            <view class="meal-block mt8" wx:if="{{n.meal}}">
              <text class="detail-label">🍽️ 餐饮</text>
              <view class="meal-item" wx:if="{{n.meal.breakfast && n.meal.breakfast !== '-'}}">
                <text class="meal-tag">早</text><text class="meal-text">{{n.meal.breakfast}}</text>
              </view>
              <view class="meal-item" wx:if="{{n.meal.lunch && n.meal.lunch !== '-'}}">
                <text class="meal-tag">午</text><text class="meal-text">{{n.meal.lunch}}</text>
              </view>
              <view class="meal-item" wx:if="{{n.meal.dinner && n.meal.dinner !== '-'}}">
                <text class="meal-tag">晚</text><text class="meal-text">{{n.meal.dinner}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- 京东酒旅推荐 -->
      <view class="card jd-block" wx:if="{{recHotels.length}}">
        <view class="row between">
          <text class="sec-title">🏨 跟着攻略订同款</text>
          <text class="jd-more">京东酒旅 ›</text>
        </view>
        <view class="hotel-card" wx:for="{{recHotels}}" wx:key="id">
          <view class="hotel-img">{{item.img}}</view>
          <view class="hotel-info">
            <view class="hotel-name">{{item.name}}</view>
            <view class="row subtitle mt8">
              <text>⭐{{item.score}}</text><text class="dot">·</text><text>{{item.city}}</text>
            </view>
            <view class="hotel-tag mt8">{{item.tag}} · 返{{item.bean}}京豆</view>
          </view>
          <view class="hotel-buy">
            <view class="hotel-price">¥{{item.price}}<text class="hotel-origin">¥{{item.origin}}</text></view>
            <view class="buy-btn" data-name="{{item.name}}" bindtap="onBookHotel">预订</view>
          </view>
        </view>
      </view>

      <!-- 行前装备种草 -->
      <view class="card jd-block" wx:if="{{gears.length}}">
        <view class="row between">
          <text class="sec-title">🎒 行前装备清单</text>
          <text class="jd-more">京东自营 ›</text>
        </view>
        <view class="jd-tip mt8">根据本攻略「{{guide.tags}}」智能推荐</view>
        <view class="gear-grid mt16">
          <view class="gear-item" wx:for="{{gears}}" wx:key="id">
            <view class="gear-img">{{item.img}}</view>
            <view class="gear-name">{{item.name}}</view>
            <view class="gear-sales">{{item.sales}}</view>
            <view class="row between gear-foot">
              <text class="gear-price">¥{{item.price}}</text>
              <view class="cart-btn" data-name="{{item.name}}" bindtap="onAddCart">+ 加购</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 共编留痕时间线 -->
      <view wx:if="{{edits.length > 0}}" class="card edit-history">
        <view class="eh-title">📜 共编留痕（{{edits.length}}）</view>
        <view wx:for="{{edits}}" wx:key="id" class="eh-item">
          <view class="eh-time">{{item.time}}</view>
          <view class="eh-content">
            Day {{planNodes[item.nodeIdx].day}} · {{planNodes[item.nodeIdx].title}}
          </view>
          <view class="eh-diff">-{{item.oldVal || '（空）'}}</view>
          <view class="eh-diff plus">+{{item.newVal}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 旅帐差额AA -->
  <view wx:elif="{{tab === 'ledger'}}" class="tab-pane">
    <view class="card">
      <view class="sec-title">💸 净转账（最少笔数）</view>
      <view wx:if="{{settlements.length === 0}}" class="empty">账目已结清，无需转账 ✨</view>
      <view wx:for="{{settlements}}" wx:key="idx" wx:for-item="s" class="settle-row">
        <text class="sr-from">{{s.fromName}}</text>
        <text class="sr-arrow"> → 转 ¥{{s.amount}} → </text>
        <text class="sr-to">{{s.toName}}</text>
      </view>
    </view>

    <view class="card">
      <view class="sec-title">📊 成员余额</view>
      <view wx:for="{{memberStats}}" wx:key="id" wx:for-item="m" class="stat-row">
        <text class="stat-avatar">{{m.avatar}}</text>
        <text class="stat-name">{{m.nickname}}</text>
        <text class="stat-paid">已付 ¥{{m.paid}}</text>
        <text class="stat-share">应付 ¥{{m.share}}</text>
        <text class="stat-net {{m.net > 0 ? 'pos' : m.net < 0 ? 'neg' : 'zero'}}">
          {{m.net > 0 ? '+' : ''}}{{m.net}}
        </text>
      </view>
    </view>

    <view class="card">
      <view class="sec-title">📒 账目明细</view>
      <view wx:if="{{ledger.length === 0}}" class="empty">还没有账目，点下方「记一笔」开始</view>
      <view wx:for="{{ledger}}" wx:key="id" wx:for-item="e" class="ledger-row">
        <view class="lr-left">
          <text class="lr-cat">{{e.category}}</text>
          <text class="lr-title">{{e.title}}</text>
          <text class="lr-meta">{{e.date}} · {{e.splits.length}}人平摊</text>
        </view>
        <view class="lr-right">
          <text class="lr-amount">¥{{e.amount}}</text>
          <text class="lr-payer">{{_memberName(e.payerId)}} 付</text>
        </view>
      </view>
    </view>

    <view class="fab-mini" bindtap="onShowAddLedger">+ 记一笔</view>
  </view>

  <!-- 成员 -->
  <view wx:elif="{{tab === 'members'}}" class="tab-pane">
    <view class="card">
      <view class="sec-title">👥 同行搭子（{{members.length}}）</view>
      <view wx:for="{{members}}" wx:key="id" wx:for-item="m" class="member-row">
        <view class="m-avatar-lg">{{m.avatar}}</view>
        <view class="m-info">
          <view class="m-name">{{m.nickname}} <text wx:if="{{m.id === 'u1'}}" class="m-me">我</text></view>
          <view class="m-tags">
            <text class="m-tag" wx:for="{{m.tags}}" wx:key="*this" wx:for-item="t">{{t}}</text>
          </view>
          <view class="m-meta">🛫 过往出行 {{m.pastTrips}} 次</view>
        </view>
        <view class="m-credit">
          <view class="mc-score">{{m.creditScore}}</view>
          <view class="mc-label">信用</view>
        </view>
      </view>
      <view class="btn btn-ghost mt16" bindtap="onInviteMember">+ 邀请搭子加入</view>
    </view>
  </view>

  <!-- 新增账目弹层 -->
  <view wx:if="{{showAddLedger}}" class="modal-mask" bindtap="onCloseAddLedger">
    <view class="modal-body" catchtap="">
      <view class="modal-title">记一笔</view>

      <view class="form-row">
        <text class="form-label">📝 项目</text>
        <input class="form-input" data-field="title" value="{{newLedger.title}}" bindinput="onLedgerInput" placeholder="如：包车费" />
      </view>
      <view class="form-row">
        <text class="form-label">💰 金额</text>
        <input class="form-input" data-field="amount" type="digit" value="{{newLedger.amount}}" bindinput="onLedgerInput" placeholder="¥" />
      </view>
      <view class="form-row">
        <text class="form-label">🏷 类别</text>
        <picker range="{{categories}}" range-key="key" value="0" bindchange="onLedgerCategory">
          <view class="picker">{{newLedger.category}} ▾</view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">💳 付款人</text>
        <picker range="{{space.members}}" range-key="nickname" value="0" bindchange="onLedgerPayer">
          <view class="picker">{{_memberName(newLedger.payerId)}} ▾</view>
        </picker>
      </view>
      <view class="form-row">
        <text class="form-label">👥 分摊</text>
        <view class="split-row">
          <text class="split-chip {{newLedger.splits.indexOf(item.id) >= 0 ? 'on' : ''}}"
                wx:for="{{space.members}}" wx:key="id" wx:for-item="m"
                data-id="{{item.id}}" bindtap="onToggleSplit">{{m.nickname}}</text>
        </view>
      </view>
      <view class="btn btn-primary mt16" bindtap="onSaveLedger">保存</view>
    </view>
  </view>

  <!-- AI 行程助手浮动入口 -->
  <view class="ai-fab" wx:if="{{tab === 'plan' && guide}}" bindtap="openAi">
    <text class="ai-fab-emoji">🤖</text>
    <text class="ai-fab-txt">AI 助手</text>
  </view>

  <!-- AI 行程助手弹层 -->
  <view class="ai-mask" wx:if="{{aiVisible}}" bindtap="closeAi"></view>
  <view class="ai-panel {{aiVisible ? 'show' : ''}}">
    <view class="row between ai-head">
      <view class="row">
        <text class="ai-head-emoji">🤖</text>
        <text class="ai-head-title">AI 行程助手·小伴</text>
        <text class="ai-head-tag">AI</text>
      </view>
      <text class="ai-close" bindtap="closeAi">✕</text>
    </view>
    <scroll-view class="ai-msgs" scroll-y scroll-into-view="{{'a-msg-' + (aiMessages.length - 1)}}">
      <view wx:for="{{aiMessages}}" wx:key="idx" id="a-msg-{{index}}" class="ai-msg {{item.from === 'user' ? 'user' : 'ai'}}">
        <text wx:if="{{item.from === 'ai'}}" class="ai-msg-avatar">🤖</text>
        <view class="ai-msg-bubble">{{item.text}}</view>
      </view>
    </scroll-view>
    <view class="ai-presets">
      <view wx:for="{{aiPresets}}" wx:key="*this" class="ai-preset" data-v="{{item.label}}" bindtap="aiPresetTap">
        <text class="ai-preset-emoji">{{item.icon}}</text>
        <text>{{item.label}}</text>
      </view>
    </view>
    <view class="ai-input-bar">
      <input class="ai-input" placeholder="告诉小伴你想调整什么…" value="{{aiInput}}" bindinput="onAiInput" bindconfirm="doSendAi" />
      <view class="ai-send" bindtap="doSendAi">发送</view>
    </view>
  </view>
</view>