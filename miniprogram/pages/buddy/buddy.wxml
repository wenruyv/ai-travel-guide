<view class="container">
  <!-- 四维筛选 -->
  <view class="card filter">
    <view class="filter-row">
      <text class="filter-label">📍地点</text>
      <input class="filter-input" placeholder="如 稻城/厦门" value="{{filters.place}}" bindinput="onPlaceInput" />
    </view>
    <view class="filter-row">
      <text class="filter-label">🎯兴趣</text>
      <picker range="{{interestOptions}}" value="{{interestIndex}}" bindchange="onInterestChange">
        <view class="picker">{{interestOptions[interestIndex]}} ▾</view>
      </picker>
    </view>
    <view class="filter-row">
      <text class="filter-label">💰预算</text>
      <picker range="{{budgetOptions}}" value="{{budgetIndex}}" bindchange="onBudgetChange">
        <view class="picker">{{budgetOptions[budgetIndex]}} ▾</view>
      </picker>
    </view>
    <view class="btn btn-primary mt16" bindtap="onFilter">开始匹配搭子</view>
  </view>

  <!-- 搭子卡片 -->
  <view class="card buddy-card" wx:for="{{list}}" wx:key="id">
    <view class="row between">
      <view class="row">
        <view class="avatar">{{item.avatar}}</view>
        <view class="ml16">
          <view class="title">{{item.nickname}}</view>
          <view class="subtitle mt8">📍{{item.destination}}</view>
        </view>
      </view>
      <view class="match">
        <view class="match-num">{{item.match}}%</view>
        <view class="match-label">匹配度</view>
      </view>
    </view>
    <view class="subtitle mt16">🗓 {{item.dateRange}} · 💰{{item.budget}}</view>
    <view class="row wrap mt16">
      <text class="tag" wx:for="{{item.interests}}" wx:for-item="it" wx:key="*this">{{it}}</text>
    </view>
    <view class="intro mt16">{{item.intro}}</view>
    <!-- 已选攻略：封面+标题+天数，点击进入攻略详情 -->
    <view wx:if="{{item.guideId}}" class="guide-card" data-gid="{{item.guideId}}" bindtap="onOpenGuide">
      <view class="gc-cover">{{item.guideCover || '🗺️'}}</view>
      <view class="gc-info">
        <view class="gc-label">已选攻略</view>
        <view class="gc-title">{{item.guideTitle || '查看攻略'}}</view>
        <view class="gc-meta">{{item.guideDestination || item.destination}} · {{item.guideDays || 0}}天</view>
      </view>
      <view class="gc-go">查看 ›</view>
    </view>
    <view wx:else class="guide-card guide-card-empty" data-id="{{item.id}}" bindtap="onPickGuide">
      <view class="gc-cover gc-cover-empty">＋</view>
      <view class="gc-info">
        <view class="gc-label">未选攻略</view>
        <view class="gc-title">帮他挑一份攻略</view>
        <view class="gc-meta">挑完即可拼成同行</view>
      </view>
      <view class="gc-go">去选 ›</view>
    </view>
    <view class="btn btn-ghost mt16" data-name="{{item.nickname}}" data-id="{{item.id}}" data-avatar="{{item.avatar}}" data-dest="{{item.destination}}" bindtap="onInvite">🤝 拼成同行</view>
  </view>

  <view wx:if="{{list.length === 0}}" class="empty">暂无匹配搭子，放宽条件试试~</view>
</view>

<view class="fab" bindtap="onPost">＋</view>