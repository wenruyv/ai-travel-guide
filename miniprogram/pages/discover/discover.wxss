.page { padding: 0 16rpx 140rpx; background: #f5f6fa; min-height: 100vh; }

/* AI 攻略生成 banner */
.ai-banner {
  display: flex;
  align-items: center;
  margin: 16rpx 8rpx 0;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #5b6ee8 0%, #7c3aed 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(91, 110, 232, 0.3);
}
.ai-banner-icon {
  font-size: 60rpx;
  margin-right: 20rpx;
  line-height: 1;
}
.ai-banner-mid { flex: 1; }
.ai-banner-title {
  font-size: 30rpx;
  font-weight: 600;
}
.ai-banner-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  opacity: 0.88;
}
.ai-banner-arrow {
  font-size: 48rpx;
  opacity: 0.7;
}

/* 顶部 tab */
.tabs {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  padding: 24rpx 0;
  position: sticky;
  top: 0;
  background: #f5f6fa;
  z-index: 5;
}
.tab { font-size: 30rpx; color: #999; padding-bottom: 8rpx; }
.tab.active {
  color: #222;
  font-weight: bold;
  border-bottom: 4rpx solid #2f80ed;
}

/* 双列瀑布流 */
.waterfall {
  column-count: 2;
  column-gap: 16rpx;
}
.post-card {
  break-inside: avoid;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.cover {
  height: 280rpx;
  background: linear-gradient(135deg, #e8f0fe, #f0f2f5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 120rpx;
}
.body { padding: 16rpx; }
.note {
  font-size: 27rpx;
  color: #222;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.loc { font-size: 22rpx; color: #999; margin-top: 8rpx; }
.foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}
.user { display: flex; align-items: center; }
.ava { font-size: 32rpx; margin-right: 8rpx; }
.uname { font-size: 24rpx; color: #666; }
.like { font-size: 24rpx; color: #666; }
.like.liked { color: #e1251b; }

.empty { text-align: center; color: #bbb; font-size: 26rpx; padding: 80rpx 0; }

/* 发布悬浮按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  background: #2f80ed;
  color: #fff;
  font-size: 30rpx;
  padding: 24rpx 40rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(47,128,237,0.4);
}