.container {
  padding-bottom: 140rpx;
}
.dot {
  margin: 0 10rpx;
  color: #ccc;
}
.edit-flag {
  color: #f2994a;
  font-size: 24rpx;
}
.author {
  font-size: 24rpx;
  color: #666;
  gap: 16rpx;
}
.online {
  color: #27ae60;
  font-size: 22rpx;
}
.pm-btn {
  margin-left: auto;
  font-size: 22rpx;
  color: #fff;
  background: #2f80ed;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
}
.tip {
  font-size: 24rpx;
}

/* 时间轴节点 */
.node {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f1f5;
}
.node-day {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #eef3fd;
  color: #2f80ed;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
}
.node-body {
  flex: 1;
  position: relative;
}
.node-title {
  font-size: 30rpx;
  font-weight: 500;
}
.node-cost {
  color: #eb5757;
  font-size: 26rpx;
}
.node-note {
  background: #fafbfc;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  color: #555;
}
.node-note-edit {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
  width: 100%;
  box-sizing: border-box;
}
/* 节点细节：时间/交通/住宿/餐饮 */
.detail-row {
  display: flex;
  align-items: flex-start;
  font-size: 24rpx;
  line-height: 1.6;
}
.detail-label {
  flex-shrink: 0;
  width: 100rpx;
  color: #888;
}
.detail-val {
  flex: 1;
  color: #444;
}
.meal-block {
  font-size: 24rpx;
}
.meal-item {
  display: flex;
  align-items: flex-start;
  margin-top: 8rpx;
  line-height: 1.6;
}
.meal-tag {
  flex-shrink: 0;
  width: 100rpx;
  text-align: center;
  background: #eef3fd;
  color: #2f80ed;
  border-radius: 8rpx;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  margin-right: 12rpx;
}
.meal-text {
  flex: 1;
  color: #444;
}
.ask-btn {
  display: inline-block;
  color: #2f80ed;
  background: #eef3fd;
  border-radius: 100rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
}

/* 楼主问答：小字列在每一步下方 */
.talks {
  margin-top: 12rpx;
  border-left: 4rpx solid #eef0f4;
  padding-left: 16rpx;
}
.talk {
  font-size: 24rpx;
  line-height: 1.6;
  color: #666;
  margin-bottom: 6rpx;
}
.talk-user {
  color: #999;
  margin-right: 8rpx;
}
.talk-text {
  color: #555;
}
/* 楼主回复：金色高亮 */
.talk.author .talk-user {
  color: #e6871e;
  font-weight: 600;
}
.talk.author .talk-text {
  color: #333;
}
/* 我发的问题：主题蓝 */
.talk.me .talk-user {
  color: #2f80ed;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  padding: 20rpx 24rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 16rpx;
}
.flex1 {
  flex: 1;
}

/* 问楼主：底部弹出面板 */
.ask-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 10;
}
.ask-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: -100%;
  background: #fff;
  z-index: 11;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 24rpx calc(32rpx + env(safe-area-inset-bottom));
  transition: bottom 0.28s ease;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
}
.ask-panel.show {
  bottom: 0;
}
.ask-head {
  margin-bottom: 24rpx;
}
.ask-close {
  font-size: 36rpx;
  color: #999;
}
.quick-qs {
  margin-bottom: 24rpx;
}
.quick-q {
  display: inline-block;
  background: #f5f6fa;
  color: #444;
  border-radius: 100rpx;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  margin: 0 12rpx 12rpx 0;
}
.ask-input-bar {
  display: flex;
  gap: 16rpx;
}
.ask-input {
  flex: 1;
  background: #f5f6fa;
  border-radius: 100rpx;
  padding: 0 28rpx;
  height: 76rpx;
  font-size: 26rpx;
}
.ask-send {
  background: #2f80ed;
  color: #fff;
  border-radius: 100rpx;
  padding: 0 40rpx;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
}

/* ===== 京东种草区块 ===== */
.jd-block .title { font-size: 30rpx; }
.jd-more {
  color: #e1251b;
  font-size: 24rpx;
}
/* 酒店卡片 */
.hotel-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f1f5;
}
.hotel-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background: #f5f6fa;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.hotel-info { flex: 1; min-width: 0; }
.hotel-name {
  font-size: 28rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.hotel-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #e1251b;
  background: #fdeceb;
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
}
.hotel-buy { text-align: right; flex-shrink: 0; }
.hotel-price {
  color: #e1251b;
  font-size: 32rpx;
  font-weight: 700;
}
.hotel-origin {
  color: #bbb;
  font-size: 22rpx;
  text-decoration: line-through;
  margin-left: 6rpx;
  font-weight: 400;
}
.buy-btn {
  margin-top: 8rpx;
  background: linear-gradient(135deg, #e1251b, #ff6034);
  color: #fff;
  border-radius: 100rpx;
  padding: 8rpx 28rpx;
  font-size: 24rpx;
}
/* 装备网格 */
.gear-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.gear-item {
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  background: #fafbfc;
  border-radius: 12rpx;
  padding: 16rpx;
}
.gear-img {
  font-size: 56rpx;
  text-align: center;
  padding: 8rpx 0;
}
.gear-name {
  font-size: 26rpx;
  line-height: 1.4;
  height: 72rpx;
  overflow: hidden;
}
.gear-sales {
  color: #999;
  font-size: 22rpx;
  margin: 6rpx 0;
}
.gear-price {
  color: #e1251b;
  font-size: 30rpx;
  font-weight: 700;
}
.cart-btn {
  background: #ffe8c2;
  color: #e6871e;
  border-radius: 100rpx;
  padding: 6rpx 20rpx;
  font-size: 22rpx;
}
/* === AI 行程助手 浮动 FAB + 弹层 === */
.ai-fab {
  position: fixed;
  right: 28rpx;
  bottom: 180rpx;
  z-index: 90;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6a82fb 0%, #7c3aed 100%);
  box-shadow: 0 12rpx 32rpx rgba(106, 130, 251, 0.45);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
  animation: aiFabPulse 2.4s ease-in-out infinite;
}
.ai-fab-emoji { font-size: 40rpx; line-height: 1; }
.ai-fab-txt { font-size: 20rpx; margin-top: 2rpx; font-weight: 600; }
@keyframes aiFabPulse {
  0%, 100% { transform: scale(1); box-shadow: 0 12rpx 32rpx rgba(106, 130, 251, 0.45); }
  50%      { transform: scale(1.06); box-shadow: 0 16rpx 40rpx rgba(124, 58, 237, 0.6); }
}

.ai-mask {
  position: fixed; inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 100;
}
.ai-panel {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 101;
  height: 70vh;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  padding-bottom: env(safe-area-inset-bottom);
}
.ai-panel.show { transform: translateY(0); }

.ai-head {
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}
.ai-head-emoji { font-size: 36rpx; margin-right: 12rpx; }
.ai-head-title { font-size: 30rpx; font-weight: 700; color: #1f1f1f; }
.ai-head-tag {
  margin-left: 12rpx;
  font-size: 20rpx;
  color: #7c3aed;
  background: #f1eafe;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}
.ai-close {
  font-size: 36rpx;
  color: #999;
  padding: 0 12rpx;
}

.ai-msgs {
  flex: 1;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}
.ai-msg {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}
.ai-msg.user { flex-direction: row-reverse; }
.ai-msg-avatar { font-size: 32rpx; margin-right: 12rpx; line-height: 1.4; }
.ai-msg.user .ai-msg-avatar { display: none; }
.ai-msg-bubble {
  max-width: 76%;
  padding: 16rpx 22rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  line-height: 1.55;
  word-break: break-all;
}
.ai-msg.ai .ai-msg-bubble {
  background: linear-gradient(135deg, #f1eafe 0%, #e0e7ff 100%);
  color: #2a1f5d;
  border-top-left-radius: 4rpx;
}
.ai-msg.user .ai-msg-bubble {
  background: linear-gradient(135deg, #6a82fb 0%, #7c3aed 100%);
  color: #fff;
  border-top-right-radius: 4rpx;
}

.ai-presets {
  padding: 16rpx 24rpx 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  border-top: 1rpx solid #f0f0f0;
}
.ai-preset {
  display: inline-flex;
  align-items: center;
  background: #f6f7fb;
  color: #4a4458;
  padding: 12rpx 22rpx;
  border-radius: 100rpx;
  font-size: 24rpx;
  border: 1rpx solid #ececf2;
}
.ai-preset-emoji { margin-right: 8rpx; font-size: 26rpx; }

.ai-input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fff;
}
.ai-input {
  flex: 1;
  background: #f6f7fb;
  border-radius: 100rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
}
.ai-send {
  background: linear-gradient(135deg, #6a82fb 0%, #7c3aed 100%);
  color: #fff;
  padding: 16rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 600;
}

/* === AI 攻略标识 === */
.ai-source {
  margin-left: 12rpx;
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #6a82fb 0%, #7c3aed 100%);
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 600;
}
.ai-summary-bar {
  background: linear-gradient(90deg, #f1eafe 0%, #e0e7ff 100%);
  color: #4a4458;
  font-size: 24rpx;
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
  line-height: 1.5;
}

/* raw 召回笔记折叠卡 */
.raw-source-tag {
  display: inline-block;
  background: linear-gradient(135deg, #ff5a7a, #ff9050);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-left: 8rpx;
}
.raw-source-bar {
  background: linear-gradient(135deg, #fff0f3, #fff5e6);
  font-size: 24rpx;
  color: #c0394d;
  padding: 14rpx 20rpx;
  border-radius: 12rpx;
  line-height: 1.5;
}
.raw-source-name {
  color: #ff5a7a;
  font-weight: 600;
}
.raw-source-card {
  background: #fff;
  border: 2rpx solid #ffd1d8;
  border-radius: 16rpx;
  padding: 20rpx;
}
.raw-card-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.raw-avatar {
  font-size: 48rpx;
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  background: #fff5e6;
  border-radius: 50%;
  flex-shrink: 0;
}
.raw-head-info {
  flex: 1;
  min-width: 0;
}
.raw-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.raw-stats {
  font-size: 22rpx;
  color: #999;
  gap: 8rpx;
  margin-top: 6rpx;
  align-items: center;
}
.raw-source-chip {
  background: linear-gradient(135deg, #ff2442, #ff5a7a);
  color: #fff;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
}
.raw-toggle {
  font-size: 22rpx;
  color: #2f80ed;
  flex-shrink: 0;
}
.raw-body {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed #ffd1d8;
}
.raw-stats2 {
  gap: 24rpx;
  font-size: 24rpx;
  color: #ff5a7a;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.raw-images {
  white-space: nowrap;
  margin: 12rpx 0 20rpx;
}
.raw-img {
  display: inline-block;
  width: 160rpx;
  height: 160rpx;
  line-height: 160rpx;
  text-align: center;
  font-size: 80rpx;
  background: linear-gradient(135deg, #ffe4ec, #fff5e6);
  border-radius: 16rpx;
  margin-right: 16rpx;
}
.raw-content {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  background: #fff8f9;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  white-space: pre-wrap;
  word-break: break-all;
}
.raw-tags {
  gap: 12rpx;
  margin-top: 16rpx;
}
.raw-tag {
  background: #fff0f3;
  color: #c0394d;
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 18rpx;
}
.raw-foot {
  margin-top: 16rpx;
  text-align: right;
}
.raw-url {
  font-size: 22rpx;
  color: #2f80ed;
}
