/* pages/space/space.wxss */
.container { padding: 0 0 200rpx; background: #f5f6f8; min-height: 100vh; }

/* 头部 */
.space-hero {
  display: flex; align-items: center; padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #fe6b6b 0%, #ff8e53 100%);
  color: #fff;
}
.sh-cover { width: 120rpx; height: 120rpx; background: rgba(255,255,255,0.2);
  border-radius: 24rpx; display: flex; align-items: center; justify-content: center;
  font-size: 72rpx; flex-shrink: 0; }
.sh-info { flex: 1; margin-left: 24rpx; }
.sh-title { font-size: 36rpx; font-weight: 700; }
.sh-meta { font-size: 24rpx; color: rgba(255,255,255,0.9); margin-top: 8rpx; }

/* tab */
.tabs { display: flex; background: #fff; border-bottom: 1rpx solid #eee; position: sticky; top: 0; z-index: 10; }
.tab { flex: 1; padding: 28rpx 0; text-align: center; font-size: 28rpx; color: #666; position: relative; }
.tab.on { color: #fe6b6b; font-weight: 700; }
.tab.on::after { content: ''; position: absolute; left: 50%; bottom: 0; transform: translateX(-50%);
  width: 48rpx; height: 4rpx; background: #fe6b6b; border-radius: 2rpx; }

.tab-pane { padding: 24rpx; }

/* 通用 card */
.card { background: #fff; border-radius: 20rpx; padding: 24rpx; margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04); }
.sec-title { font-size: 30rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 16rpx; }
.empty { text-align: center; color: #999; padding: 40rpx 0; font-size: 26rpx; }

/* ===== 行程共编 ===== */
.plan-node { padding: 24rpx; }
.pn-day { display: inline-block; padding: 4rpx 16rpx; background: #fff7f0;
  color: #ff8e53; font-size: 22rpx; font-weight: 700; border-radius: 8rpx; }
.pn-title { font-size: 32rpx; font-weight: 700; color: #1a1a1a; margin-top: 12rpx; }
.pn-loc { font-size: 24rpx; color: #888; margin-top: 8rpx; }
.pn-note { margin-top: 16rpx; padding: 16rpx; background: #f8f9fa; border-radius: 12rpx;
  font-size: 26rpx; color: #555; line-height: 1.6; border: 2rpx dashed transparent; }
.pn-edit { margin-top: 16rpx; padding: 16rpx; background: #fff7f0; border-radius: 12rpx; }
.pn-input { width: 100%; font-size: 26rpx; min-height: 80rpx; padding: 8rpx; }

.edit-history { background: #fafbfc; }
.eh-title { font-size: 26rpx; font-weight: 700; color: #555; margin-bottom: 16rpx; }
.eh-item { padding: 16rpx 0; border-top: 1rpx solid #eee; }
.eh-item:first-of-type { border-top: none; }
.eh-time { font-size: 22rpx; color: #999; }
.eh-content { font-size: 26rpx; color: #1a1a1a; margin: 6rpx 0; }
.eh-diff { font-size: 24rpx; color: #999; margin: 2rpx 0; }
.eh-diff.plus { color: #27ae60; }

/* ===== 旅帐 ===== */
.settle-row { display: flex; align-items: center; padding: 12rpx 0; font-size: 26rpx; }
.sr-from { color: #fe6b6b; font-weight: 700; }
.sr-arrow { color: #999; margin: 0 8rpx; }
.sr-to { color: #27ae60; font-weight: 700; }

.stat-row { display: flex; align-items: center; padding: 12rpx 0;
  border-top: 1rpx solid #f5f5f5; }
.stat-row:first-of-type { border-top: none; }
.stat-avatar { font-size: 36rpx; margin-right: 12rpx; }
.stat-name { flex: 0 0 120rpx; font-size: 26rpx; color: #1a1a1a; font-weight: 600; }
.stat-paid, .stat-share { flex: 0 0 140rpx; font-size: 22rpx; color: #888; }
.stat-net { flex: 1; text-align: right; font-size: 28rpx; font-weight: 700; }
.stat-net.pos { color: #27ae60; }
.stat-net.neg { color: #fe6b6b; }
.stat-net.zero { color: #999; }

.ledger-row { display: flex; align-items: center; padding: 16rpx 0; border-top: 1rpx solid #f5f5f5; }
.ledger-row:first-of-type { border-top: none; }
.lr-left { flex: 1; }
.lr-cat { display: inline-block; padding: 2rpx 12rpx; background: #fff7f0; color: #ff8e53;
  font-size: 20rpx; border-radius: 6rpx; margin-right: 8rpx; }
.lr-title { font-size: 28rpx; color: #1a1a1a; }
.lr-meta { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.lr-right { text-align: right; }
.lr-amount { display: block; font-size: 32rpx; font-weight: 700; color: #1a1a1a; }
.lr-payer { display: block; font-size: 22rpx; color: #999; }

.fab-mini {
  position: fixed; right: 40rpx; bottom: 100rpx;
  padding: 16rpx 32rpx; background: linear-gradient(135deg, #fe6b6b 0%, #ff8e53 100%);
  color: #fff; border-radius: 48rpx; font-size: 28rpx; font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(254,107,107,0.4); z-index: 99;
}

/* ===== 成员 ===== */
.member-row { display: flex; align-items: center; padding: 20rpx 0;
  border-top: 1rpx solid #f5f5f5; }
.member-row:first-of-type { border-top: none; }
.m-avatar-lg { width: 100rpx; height: 100rpx; background: #fff7f0; border-radius: 50%;
  display: flex; align-items: center; justify-content: center; font-size: 56rpx; flex-shrink: 0; }
.m-info { flex: 1; margin-left: 20rpx; min-width: 0; }
.m-name { font-size: 30rpx; font-weight: 700; color: #1a1a1a; }
.m-me { display: inline-block; padding: 2rpx 12rpx; background: #fe6b6b; color: #fff;
  font-size: 20rpx; border-radius: 6rpx; margin-left: 8rpx; font-weight: 400; }
.m-tags { margin-top: 8rpx; }
.m-tag { display: inline-block; padding: 2rpx 12rpx; background: #f0f0f0; color: #666;
  font-size: 20rpx; border-radius: 6rpx; margin-right: 8rpx; }
.m-meta { font-size: 22rpx; color: #999; margin-top: 6rpx; }
.m-credit { text-align: center; }
.mc-score { font-size: 36rpx; font-weight: 700; color: #27ae60; }
.mc-label { font-size: 20rpx; color: #999; }

/* ===== 弹层 ===== */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 999; display: flex; align-items: flex-end; }
.modal-body { width: 100%; max-height: 80vh; background: #fff;
  border-radius: 32rpx 32rpx 0 0; padding: 32rpx; }
.modal-title { font-size: 32rpx; font-weight: 700; text-align: center; margin-bottom: 16rpx; }
.form-row { display: flex; align-items: center; padding: 20rpx 0; border-top: 1rpx solid #f0f0f0; }
.form-row:first-of-type { border-top: none; }
.form-label { width: 160rpx; font-size: 28rpx; color: #333; }
.form-input { flex: 1; font-size: 28rpx; }
.picker { flex: 1; font-size: 28rpx; }
.split-row { flex: 1; display: flex; flex-wrap: wrap; gap: 12rpx; }
.split-chip { padding: 8rpx 20rpx; background: #f5f6f8; border-radius: 24rpx; font-size: 24rpx; }
.split-chip.on { background: #fe6b6b; color: #fff; }

/* 通用按钮 */
.btn { display: flex; align-items: center; justify-content: center;
  height: 80rpx; border-radius: 12rpx; font-size: 28rpx; font-weight: 600; }
.btn-primary { background: linear-gradient(135deg, #fe6b6b 0%, #ff8e53 100%); color: #fff; }
.btn-ghost { background: #fff; color: #fe6b6b; border: 2rpx solid #fe6b6b; }

.row { display: flex; align-items: center; }
.ml8 { margin-left: 16rpx; }
.mt8 { margin-top: 8rpx; }
.mt16 { margin-top: 16rpx; }