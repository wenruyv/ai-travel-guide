.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #ededed;
}

.msg-list {
  flex: 1;
  padding: 20rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.msg-day {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin: 16rpx 0 28rpx;
}

.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.msg-row.mine {
  flex-direction: row-reverse;
}

.msg-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 12rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
}

.msg-bubble {
  max-width: 480rpx;
  margin: 0 18rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.5;
  color: #222;
  background: #fff;
  position: relative;
  word-break: break-word;
}

.msg-row.mine .msg-bubble {
  background: #95ec69;
}

.msg-time {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 8rpx;
}

.msg-row.mine .msg-time {
  text-align: right;
  color: #5a7a3f;
}

.chat-input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #f7f7f7;
  border-top: 1rpx solid #e0e0e0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.chat-send {
  margin-left: 18rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #fff;
  background: #b0d89a;
}

.chat-send.active {
  background: #07c160;
}

/* ===== 旅行空间卡片 ===== */
.space-card {
  display: flex; align-items: center;
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: linear-gradient(135deg, #ff8e53 0%, #fe6b6b 100%);
  border-radius: 20rpx;
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(254, 107, 107, 0.3);
}
.sc-cover {
  width: 96rpx; height: 96rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx; flex-shrink: 0;
}
.sc-info { flex: 1; margin-left: 20rpx; min-width: 0; }
.sc-title { font-size: 30rpx; font-weight: 700; color: #fff;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sc-meta { font-size: 22rpx; color: rgba(255,255,255,0.85); margin-top: 6rpx; }
.sc-members { margin-top: 8rpx; display: flex; align-items: center; }
.sc-avatar {
  width: 40rpx; height: 40rpx; line-height: 40rpx; text-align: center;
  background: rgba(255,255,255,0.9); border-radius: 50%;
  font-size: 24rpx; margin-right: -8rpx;
  border: 2rpx solid #fe6b6b;
}
.sc-edit { font-size: 20rpx; color: #fff; margin-left: 24rpx; }
.sc-go { font-size: 26rpx; color: #fff; font-weight: 600; flex-shrink: 0; }

.space-cta {
  display: flex; align-items: center;
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: #fff;
  border: 2rpx dashed #fe6b6b;
  border-radius: 20rpx;
  color: #555;
}
.sc-cta-icon { font-size: 56rpx; margin-right: 20rpx; }
.sc-cta-info { flex: 1; }
.sc-cta-title { font-size: 28rpx; font-weight: 700; color: #1a1a1a; }
.sc-cta-sub { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.sc-cta-go { font-size: 26rpx; color: #fe6b6b; font-weight: 600; }