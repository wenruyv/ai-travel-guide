.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.search-input {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 100rpx;
  padding: 0 24rpx;
  height: 76rpx;
}
.search-icon {
  margin-right: 12rpx;
}
.search-input input {
  flex: 1;
  font-size: 26rpx;
}
.search-btn {
  background: linear-gradient(135deg, #2f80ed, #56ccf2);
  color: #fff;
  border-radius: 100rpx;
  padding: 0 32rpx;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 28rpx;
}

.guide-card {
  padding: 0;
  overflow: hidden;
}
.cover {
  height: 220rpx;
  background: linear-gradient(135deg, #eef3fd, #e0f7fa);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 100rpx;
}
.guide-body {
  padding: 24rpx;
}
.dot {
  margin: 0 10rpx;
  color: #ccc;
}
.stat {
  font-size: 22rpx;
  color: #8a8a8a;
}

.empty {
  text-align: center;
  color: #aaa;
  padding: 80rpx 0;
  font-size: 26rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2f80ed, #56ccf2);
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(47, 128, 237, 0.4);
}

/* 来源类型标签 */
.source-badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  font-weight: 500;
}
.source-ai {
  background: #f1eafe;
  color: #7c3aed;
}
.source-xhs {
  background: #fdeceb;
  color: #ff2442;
}
.source-mafengwo {
  background: #e8f5e9;
  color: #2e7d32;
}
.source-local {
  background: #eef3fd;
  color: #2f80ed;
}