/* pages/hotel/hotel.wxss 京东酒旅频道 */
.page { padding: 24rpx; }

/* banner */
.banner {
  background: linear-gradient(135deg, #e1251b, #ff5a4d);
  border-radius: 20rpx;
  padding: 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}
.banner-tag {
  display: inline-block;
  background: #ffd400;
  color: #7a3b00;
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}
.banner-title { font-size: 36rpx; font-weight: bold; }
.banner-desc { font-size: 24rpx; opacity: 0.9; margin-top: 8rpx; }

/* tabs */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
}
.tab-active {
  background: #e1251b;
  color: #fff;
  font-weight: bold;
}

/* 列表卡片 */
.list { display: flex; flex-direction: column; gap: 20rpx; }
.card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-img {
  width: 120rpx;
  height: 120rpx;
  font-size: 64rpx;
  line-height: 120rpx;
  text-align: center;
  background: #f5f6fa;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.card-body { flex: 1; display: flex; flex-direction: column; }
.card-name { font-size: 30rpx; font-weight: bold; color: #222; }
.card-sub { font-size: 24rpx; color: #999; margin-top: 6rpx; }
.card-tag {
  display: inline-block;
  align-self: flex-start;
  background: #fff0ef;
  color: #e1251b;
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 10rpx;
}
.card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}
.price-box { display: flex; align-items: baseline; gap: 8rpx; }
.price { color: #e1251b; font-size: 34rpx; font-weight: bold; }
.origin { color: #bbb; font-size: 24rpx; text-decoration: line-through; }
.bean { color: #ff8a00; font-size: 22rpx; }
.btn {
  background: #e1251b;
  color: #fff;
  font-size: 26rpx;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
}